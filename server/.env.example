########################################
# CORE
########################################
NODE_ENV=development
PORT=5001
API_PREFIX=/api/v1
APP_URL=http://localhost:5001
CLIENT_URL=http://localhost:5173

########################################
# AUTHENTICATION MODE
########################################
# standalone : the module manages its own users/login. Use this to run
#              the module by itself, for demos, and for unit/integration
#              testing — no host application is required. A default
#              admin account is created automatically at boot from the
#              STANDALONE_ADMIN_* values below.
# host       : authentication is handled entirely by the existing
#              application you're integrating into. This module expects
#              req.user to already be populated by the time a request
#              reaches it — see README > Integration Guide. In this
#              mode, do not use createApp()/server.js at all; mount
#              `damRouter` directly into your host Express app instead.
AUTH_MODE=standalone

# --- Only used when AUTH_MODE=standalone ---
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
STANDALONE_ADMIN_EMAIL=admin@example.com
STANDALONE_ADMIN_PASSWORD=ChangeMe123!

########################################
# DATABASE
########################################
MONGO_URI=mongodb://127.0.0.1:27017/dam_module

########################################
# REDIS (metadata cache, search cache, rate-limit store)
########################################
REDIS_URL=redis://127.0.0.1:6379
REDIS_TTL_SECONDS=300

########################################
# CLOUDINARY (storage provider for this module)
########################################
# STORAGE_PROVIDER is normally left at its default (cloudinary). "local"
# is available for local development/tests without hitting a real
# Cloudinary account — see README > Storage Adapter Architecture.
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_ROOT_FOLDER=dam
CLOUDINARY_SECURE=true

########################################
# UPLOAD LIMITS
########################################
MAX_UPLOAD_SIZE_MB=100
MAX_FILES_PER_REQUEST=20
CHUNK_SIZE_MB=5
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,image/svg+xml,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation,text/plain,text/csv,application/json,application/zip
BLOCKED_EXTENSIONS=.exe,.sh,.bat,.cmd,.msi,.dll,.com,.scr,.jar,.ps1,.vbs,.js,.php,.py,.rb

########################################
# SECURITY
########################################
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=300
UPLOAD_RATE_LIMIT_MAX_REQUESTS=60
TRUST_PROXY=1
SIGNED_URL_SECRET=change_this_to_a_long_random_string
AUDIT_LOG_RETENTION_DAYS=180

# Virus scan integration hook (optional, e.g. ClamAV daemon / cloud AV API)
VIRUS_SCAN_ENABLED=false
VIRUS_SCAN_PROVIDER=clamav
VIRUS_SCAN_HOST=127.0.0.1
VIRUS_SCAN_PORT=3310

########################################
# LOGGING
########################################
LOG_LEVEL=info
